# Gemini AI. For production, prefer a server-side proxy rather than exposing this key in the browser bundle.
# VITE_GEMINI_API_KEY is used by the browser UI; GEMINI_API_KEY is kept for legacy AI Studio compatibility.
VITE_GEMINI_API_KEY=""
GEMINI_API_KEY=""
VITE_GEMINI_MODEL="gemini-2.5-flash"

# App URL used by hosted preview/deploy environments.
APP_URL="http://localhost:3000"

# Auth mode:
# - firebase: Google/Firebase auth first, with Local Admin fallback if Firebase fails.
# - local: no Firebase login required; fastest Termux/local repair mode.
VITE_AUTH_PROVIDER="local"

# Data provider:
# - local: browser localStorage; no external database required.
# - firebase: Firestore first, local fallback on permission/config errors.
# - supabase: use Supabase when URL/key are provided; otherwise falls back per app logic.
VITE_DATA_PROVIDER="local"

# Supabase configuration for backend database and storage services.
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""
