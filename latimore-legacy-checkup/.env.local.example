# Supabase
# The project URL you shared is pre-filled here.
SUPABASE_URL=https://eoihgvahvfpgbromvzkd.supabase.co

# Server-only key. Get this from Supabase > Project Settings > API > service_role.
# Never expose this in frontend code or public GitHub repos.
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key

# Optional public values for other client-side Supabase usage.
NEXT_PUBLIC_SUPABASE_URL=https://eoihgvahvfpgbromvzkd.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_anon_key

# Resend email automation
# Requires a Resend API key and verified sending domain.
RESEND_API_KEY=replace_with_resend_api_key
RESEND_FROM_EMAIL="Latimore Life & Legacy <noreply@yourdomain.com>"
RESEND_REPLY_TO=jackson@yourdomain.com
RESEND_INTERNAL_NOTIFY_TO=jackson@yourdomain.com

# Public site URL used in email links when needed.
NEXT_PUBLIC_SITE_URL=https://latimorelifelegacy.com
