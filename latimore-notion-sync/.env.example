# Supabase project that powers latimore-hub-main, holding the unified
# leads/events/bookings schema from supabase-unified/.
# Use the service role key so the worker can read all rows.
# Set these with `ntn workers env set` — never commit real values.
SUPABASE_URL=https://eoihgvahvfpgbromvzkd.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key

# Required when running `ntn workers exec` locally against a real Notion workspace.
# Deployed workers receive this automatically.
NOTION_API_TOKEN=
